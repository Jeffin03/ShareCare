rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * PORTFOLIO MODE: READ-ONLY LOCKDOWN
     * 
     * This project has been successfully completed and archived. 
     * To preserve the integrity of the demonstration data, all 
     * write operations are now disabled globally.
     * 
     * Visitors can still read all collections to explore the 
     * patient dashboards, pharmacy portal, and community feed.
     */

    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
